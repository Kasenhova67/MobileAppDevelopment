<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/buttonGrid"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:layout_marginTop="@dimen/grid_margin_top"
    android:background="#CDA8FB"
    android:columnCount="4"
    android:rowCount="5"
    android:padding="@dimen/grid_padding">

    <Button
        android:id="@+id/btn7"
        style="@style/CalcButton"
        android:text="7" />

    <Button
        android:id="@+id/btn8"
        style="@style/CalcButton"
        android:text="8" />

    <Button
        android:id="@+id/btn9"
        style="@style/CalcButton"
        android:text="9" />

    <Button
        android:id="@+id/btnDivide"
        style="@style/OperatorButton"
        android:text="/" />

    <Button
        android:id="@+id/btn4"
        style="@style/CalcButton"
        android:text="4" />

    <Button
        android:id="@+id/btn5"
        style="@style/CalcButton"
        android:text="5" />

    <Button
        android:id="@+id/btn6"
        style="@style/CalcButton"
        android:text="6" />

    <Button
        android:id="@+id/btnMultiply"
        style="@style/OperatorButton"
        android:text="*" />

    <Button
        android:id="@+id/btn1"
        style="@style/CalcButton"
        android:text="1" />

    <Button
        android:id="@+id/btn2"
        style="@style/CalcButton"
        android:text="2" />

    <Button
        android:id="@+id/btn3"
        style="@style/CalcButton"
        android:text="3" />

    <Button
        android:id="@+id/btnMinus"
        style="@style/OperatorButton"
        android:text="-" />

    <Button
        android:id="@+id/btnClear"
        style="@style/OperatorButton"
        android:text="C" />

    <Button
        android:id="@+id/btn0"
        style="@style/CalcButton"
        android:text="0" />

    <Button
        android:id="@+id/btnDot"
        style="@style/CalcButton"
        android:text="." />

    <Button
        android:id="@+id/btnPlus"
        style="@style/OperatorButton"
        android:text="+" />

    <Button
        android:id="@+id/btnBackspace"
        style="@style/OperatorButton"
        android:layout_columnSpan="2"
        android:text="⌫" />

    <Button
        android:id="@+id/btnEquals"
        style="@style/OperatorButton"
        android:layout_columnSpan="2"
        android:text="=" />

</GridLayout>